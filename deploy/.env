# =============================================================================
# Esquire Deployment — 192.168.1.104 (HTTPS)
# PostgreSQL already running on host
# =============================================================================

# --- Host IP ---
DEPLOY_HOST=192.168.1.104

# --- PostgreSQL (external, running on host) ---
POSTGRES_DB=esq2025
POSTGRES_USER=esq2025
POSTGRES_PASSWORD=q

# --- Keycloak ---
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=q

# --- Keycloak realm ---
KEYCLOAK_REALM=esquire
KEYCLOAK_CLIENT_ID=esq-angular

# --- Logging ---
LOG_LEVEL_ROOT=ERROR
LOG_LEVEL_SF=ERROR
LOG_LEVEL_MIR0N=DEBUG
