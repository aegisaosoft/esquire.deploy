# =============================================================================
# Esquire Deployment
# PostgreSQL already running on host
#
# DEPLOY_HOST is auto-injected by Jenkins pipeline or deploy-k8s.sh.
# For manual Docker Compose usage, set it to the server IP before running.
# =============================================================================

# --- Host IP (set before deploy or leave for auto-detection) ---
DEPLOY_HOST=

# --- PostgreSQL (external, running on host) ---
POSTGRES_DB=esq2025
POSTGRES_USER=esq2025
POSTGRES_PASSWORD=q

# --- Keycloak ---
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=q

# --- Keycloak realm ---
KEYCLOAK_REALM=esquire
KEYCLOAK_CLIENT_ID=esq-angular

# --- Logging ---
LOG_LEVEL_ROOT=ERROR
LOG_LEVEL_SF=ERROR
LOG_LEVEL_MIR0N=DEBUG
